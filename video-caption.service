[Unit]
Description=Video Caption Extraction Service
After=network.target

[Service]
Type=simple
User=admin
WorkingDirectory=/home/admin/video-caption-service
EnvironmentFile=/home/admin/video-caption-service/.env
ExecStart=/home/admin/video-caption-service/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --log-level info --access-log
Restart=on-failure
RestartSec=5
StandardOutput=append:/home/admin/video-caption-service/logs/service.log
StandardError=append:/home/admin/video-caption-service/logs/service.log

[Install]
WantedBy=multi-user.target
